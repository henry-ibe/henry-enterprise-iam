# Keycloak Admin Credentials
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=your_secure_password_here

# Internal/local config
KC_URL=http://localhost:8180
KC_PORT=8180
KC_HOSTNAME=ipa1.henry-iam.internal
KC_REALM=henry-enterprise
KC_VERSION=25.0.6
KC_DEMO_MODE=true

# External config — update with your EC2 public IP
KC_PUBLIC_IP=YOUR_EC2_PUBLIC_IP
KC_EXTERNAL_URL=http://YOUR_EC2_PUBLIC_IP:8180

# Docker/Podman Variables
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_password_here
KC_DB_PASSWORD=your_db_password_here
